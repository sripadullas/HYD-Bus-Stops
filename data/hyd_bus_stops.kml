Papa.parse("data/hyd_stops.csv", {
    download: true,
    header: true,
    complete: function(results) {
        results.data.forEach(function(stop) {
            if (stop.stop_lat && stop.stop_lon) {
                L.circleMarker(
                    [parseFloat(stop.stop_lat), parseFloat(stop.stop_lon)],
                    {
                        radius: 4,
                        color: "blue"
                    }
                )
                .addTo(map)
                .bindPopup(`<b>${stop.stop_name}</b>`);
            }
        });
    }
});
